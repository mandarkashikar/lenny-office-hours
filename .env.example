# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to git (it's in .gitignore)

# OpenRouter API key for LLM responses and embeddings
# Get one free at https://openrouter.ai
OPENROUTER_API_KEY=your_api_key_here

# Model to use for guest responses
# Currently using Qwen's free tier for cost efficiency
OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free
